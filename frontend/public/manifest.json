{
  "manifest_version": 3,
  "name": "Quantum AI - Browser Companion",
  "version": "1.0.0",
  "description": "An intelligent browser companion that understands the current webpage.",
  "action": {
    "default_title": "Open Quantum AI"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["readability.js", "extraction.js", "contentScript.js"]
    }
  ],
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "sidePanel",
    "contextMenus",
    "tabs"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "commands": {
    "toggle-quantum-ai": {
      "suggested_key": {
        "default": "Ctrl+Shift+Q",
        "mac": "Command+Shift+Q"
      },
      "description": "Toggle Quantum AI side panel"
    }
  }
}
